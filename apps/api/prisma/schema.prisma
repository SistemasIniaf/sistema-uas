// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  administrador
  responsable
  operador
  auditor
}

model Unidad {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  activo      Boolean   @default(true)
  usuarios    Usuario[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  semilleras Semillera[]

  @@map("unidad")
}

model Usuario {
  id       Int     @id @default(autoincrement())
  nombre   String
  usuario  String  @unique
  password String
  rol      Rol
  activo   Boolean @default(true)
  unidadId Int?
  unidad   Unidad? @relation(fields: [unidadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuario")
}

model Producto {
  id         Int        @id @default(autoincrement())
  nombre     String     @unique
  activo     Boolean    @default(true)
  variedades Variedad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productos")
}

model Variedad {
  id         Int      @id @default(autoincrement())
  nombre     String
  activo     Boolean  @default(true)
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productoId, nombre])
  @@map("variedades")
}

model Categoria {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categorias")
}

model Semillera {
  id        Int     @id @default(autoincrement())
  nombre    String
  telefono  String
  direccion String?
  activo    Boolean @default(true)
  unidadId  Int
  unidad    Unidad  @relation(fields: [unidadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("semilleras")
}
